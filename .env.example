DISCORD_TOKEN="YOUR_DISCORD_BOT_TOKEN_HERE"

# Optional: guild-scoped command sync (faster during development).
GUILD_ID=""

# SQLite database file path (local dev). On Railway, railpack.json sets
# /data/cultivation_bot.sqlite3 — mount a volume at /data (see railway.json).
DATABASE_PATH="cultivation_bot.sqlite3"

# Optional: channel id for announcements (breakthrough/PvP).
ANNOUNCE_CHANNEL_ID=""

# Channel where the full tutorial is posted (py -m src.post_tutorial or /post-tutorial).
TUTORIAL_CHANNEL_ID=""

# Channel for the technique manual library (py -m src.post_library or /post-library).
LIBRARY_CHANNEL_ID=""

# Optional: category where private player abode channels are created (/start).
ABODE_CATEGORY_ID=""

# Optional: category for cooperative dungeon expedition channels (/dungeon).
# If unset, the bot finds or creates a "Dungeons" category (like Abodes).
DUNGEON_CATEGORY_ID=""

# Optional: category for temporary PvP arena channels (/duel accept).
ARENA_CATEGORY_ID=""

# Permanent channel where completed PvP results are posted.
PVP_RESULTS_CHANNEL_ID=""

# Logging
LOG_LEVEL="DEBUG"
SQLALCHEMY_ECHO=0

